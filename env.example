# Copie para .env.local e preencha:
# cp env.example .env.local

# ── Candidaturas (site) ──
# E-mail que recebe as candidaturas de não alunos
CANDIDATURA_EMAIL_TO=contato.vinicaetano93@gmail.com

# Chave em https://resend.com/api-keys (tipo "Sending access")
RESEND_API_KEY=re_sua_chave_aqui

# Testes: use onboarding@resend.dev (só envia para o e-mail da conta Resend)
# Produção: use domínio verificado, ex. AMET Saúde & Estética <estagios@seudominio.com.br>
RESEND_FROM_EMAIL=AMET Saúde & Estética <onboarding@resend.dev>

# ── AVA (ambiente virtual) ──
# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js / NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET=troque_por_um_segredo_longo

# URL pública do app (produção)
AUTH_URL=http://localhost:3000

# Primeiro admin (criado automaticamente se ainda não existir nenhum admin)
AVA_BOOTSTRAP_ADMIN_EMAIL=admin@amet.local
AVA_BOOTSTRAP_ADMIN_PASSWORD=troque_esta_senha

# Cloudflare R2 (upload de vídeo-aulas)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=amet-ava

# Limite opcional de upload (bytes). Default: 2GB
# AVA_MAX_VIDEO_BYTES=2147483648

# ── AVA AI (opcional) ──
# Se ausente, o assistente responde em modo "guia assistido"
# AVA_AI_ENABLED=1
# AVA_OPENAI_API_KEY=
# AVA_AI_MODEL=gpt-4.1-mini
