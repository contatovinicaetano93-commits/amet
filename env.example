# Copie para .env.local e preencha a chave do Resend:
# cp env.example .env.local

# E-mail que recebe as candidaturas de não alunos
CANDIDATURA_EMAIL_TO=contato.vinicaetano93@gmail.com

# Chave em https://resend.com/api-keys (tipo "Sending access")
RESEND_API_KEY=re_sua_chave_aqui

# Testes: use onboarding@resend.dev (só envia para o e-mail da conta Resend)
# Produção: use domínio verificado, ex. AMET Saúde & Estética <estagios@seudominio.com.br>
RESEND_FROM_EMAIL=AMET Saúde & Estética <onboarding@resend.dev>
