// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Candidatura {
  id               String   @id @default(cuid())
  cpf              String
  nomeCompleto     String
  rgm              String
  telefone         String
  email            String
  unidade          String
  areaInteresse    String
  periodo          String
  isAluno          Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@unique([cpf, areaInteresse, periodo])
  @@index([areaInteresse])
  @@index([unidade])
  @@index([periodo])
}

model Lead {
  id               String   @id @default(cuid())
  cpf              String   @unique
  nomeCompleto     String
  email            String
  telefone         String
  createdAt        DateTime @default(now())
}
